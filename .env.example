# Mini SCADA — environment variables
# Copy to .env and fill in real values

AGENT_ID=bench-01

# RabbitMQ connection
RABBIT_HOST=vlahovski.info
RABBIT_PORT=5672
RABBIT_USER=scada
RABBIT_PASS=CHANGE_ME
RABBIT_VHOST=/

# Electron GUI (amqp://user:pass@host:port/vhost)
RABBIT_URL=amqp://scada:CHANGE_ME@vlahovski.info:5672/

# Operators REST API (used for NFC badge lookup)
OPERATORS_API_BASE=https://vlahovski.info/api/v1

# NFC mock (dev mode only) — UID of the test badge registered in the DB
MOCK_NFC_UID=DEADBEEF
