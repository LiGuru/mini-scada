{
  "author": "NVLab",
  "name": "ait-electron-gui",
  "version": "0.4.2",
  "description": "AIT Test Bench GUI",
  "main": "main.js",
  "scripts": {
    "start": "NODE_ENV=production electron .",
    "dev": "NODE_ENV=development electron .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.endurosat.mini-scada",
    "productName": "Mini SCADA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github"
    },
    "asarUnpack": [
      "**/node_modules/occt-import-js/**",
      "**/node_modules/@pokusew/pcsclite/**",
      "**/node_modules/nfc-pcsc/**"
    ]
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "dotenv": "^17.4.2",
    "nfc-pcsc": "^0.8.1",
    "occt-import-js": "^0.0.23",
    "three": ">=0.160.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nvlahovski-endurosat/mini-scada.git"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-reload": "^2.0.0-alpha.1"
  }
}
