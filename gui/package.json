{
  "author": "NVLab",
  "name": "ait-electron-gui",
  "version": "0.4.2",
  "description": "AIT Test Bench GUI",
  "main": "main.js",
  "scripts": {
    "start": "NODE_ENV=production electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.endurosat.mini-scada",
    "productName": "Mini SCADA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github"
    }
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "nfc-pcsc": "^0.8.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nvlahovski-endurosat/mini-scada.git"
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-reload": "^2.0.0-alpha.1"
  }
}
